---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Casas Prefabricadas Chile | Living House — Financiamiento Directo',
  description = 'Catálogo de casas prefabricadas con financiamiento directo, con o sin DICOM. Modelos desde 36m² hasta 150m². Entrega a todo Chile.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/casa_favicon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Casas Living House" />
  <meta name="keywords" content="casas prefabricadas Chile, viviendas prefabricadas, Living House, financiamiento directo, sin DICOM, casas modulares, sur de Chile, cabañas prefabricadas" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_CL" />
  <meta property="og:site_name" content="Casas Living House" />
  <meta property="og:image" content="/casaslivinghouse.jpg" />
  <meta property="og:image:alt" content="Casas Living House — Casas Prefabricadas Chile" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="/casaslivinghouse.jpg" />

  <!-- Montserrat font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/style.css" />

  <!-- Alpine.js (cargado antes del body para evitar flashes) -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>

  <!-- JSON-LD LocalBusiness -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Casas Living House",
    "description": "Empresa chilena especializada en casas prefabricadas de calidad con financiamiento directo, con o sin DICOM.",
    "telephone": "+56930754516",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "CL"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+56930754516",
      "contactType": "sales",
      "availableLanguage": "Spanish"
    }
  }
  </script>
</head>
<body style="font-family: 'Montserrat', sans-serif; line-height: 1.6; margin: 0; padding: 0;">
  <slot />

  <!-- Lucide icons (al final del body para que el DOM esté listo) -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    if (window.lucide) window.lucide.createIcons();
  </script>
</body>
</html>
