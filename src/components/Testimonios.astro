---
// Testimonios — replica exacta de testimonios.py
const VIDEOS = [
  { src: "/testimonio1.mp4" },
  { src: "/testimonio2.mp4" },
  { src: "/testimonio3.mp4" },
  { src: "/testimonio4.mp4" },
];
---

<!-- Testimonios — replica exacta de testimonios.py -->
<div
  class="relative w-full overflow-hidden"
  style="background: linear-gradient(135deg, #0f766e 0%, #134e4a 45%, #115e59 100%);"
>
  <!-- Glows decorativos de fondo -->
  <div
    class="absolute top-0 left-0 w-96 h-96 rounded-full pointer-events-none blur-3xl opacity-10"
    style="background: radial-gradient(circle, #14b8a6 0%, transparent 70%);"
  ></div>
  <div
    class="absolute bottom-0 right-0 w-80 h-80 rounded-full pointer-events-none blur-3xl"
    style="background: radial-gradient(circle, #0f766e 0%, transparent 70%); opacity: 0.08;"
  ></div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <!-- Header -->
    <div class="mb-14">
      <p class="text-teal-400 text-xs font-bold uppercase tracking-widest mb-4">CLIENTES REALES</p>
      <div class="text-3xl md:text-5xl font-bold leading-tight mb-4">
        <span class="text-white">Familias que ya tienen </span>
        <span style="background: linear-gradient(90deg, #14b8a6 0%, #2dd4bf 50%, #5eead4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          su casa propia
        </span>
      </div>
      <p class="text-slate-400 text-base mb-8 max-w-xl">
        Mira lo que nuestros clientes dicen sobre su experiencia con Living House.
      </p>
      <a href="https://wa.me/56930754516" target="_blank" rel="noopener noreferrer" class="no-underline inline-block">
        <button class="flex items-center gap-2 bg-teal-600 hover:bg-teal-500 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-200 shadow-lg shadow-teal-900/50 text-sm border-0 cursor-pointer">
          <i data-lucide="message-circle" class="w-4 h-4" style="width:16px;height:16px;"></i>
          Contáctanos por WhatsApp
        </button>
      </a>
    </div>

    <!-- Grid de videos -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-5">
      {VIDEOS.map(v => (
        <div
          class="rounded-2xl overflow-hidden bg-slate-900 shadow-xl transition-all duration-300 hover:-translate-y-1"
          style="box-shadow: 0 8px 32px rgba(0,0,0,0.6);"
        >
          <video
            controls
            preload="metadata"
            class="w-full h-auto block max-h-80 sm:max-h-none object-cover"
          >
            <source src={v.src} type="video/mp4" />
          </video>
        </div>
      ))}
    </div>

    <!-- TikTok embed destacado -->
    <div class="mt-8">
      <div
        class="rounded-2xl overflow-hidden bg-slate-900 shadow-xl transition-all duration-300 mx-auto hover:-translate-y-1"
        style="width:325px; height:735px; box-shadow: 0 8px 32px rgba(0,0,0,0.6);"
      >
        <iframe
          src="https://www.tiktok.com/embed/v2/7594979573838728469"
          allow="encrypted-media"
          allowfullscreen
          scrolling="no"
          style="border:none; width:100%; height:100%;"
        ></iframe>
      </div>
    </div>

    <!-- Botón ver más TikTok -->
    <div class="flex justify-center mt-10">
      <a href="https://www.tiktok.com/@casaslivinghouse?lang=es" target="_blank" rel="noopener noreferrer" class="no-underline">
        <button class="flex items-center gap-3 bg-white/10 hover:bg-white/20 border border-white/25 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-200 text-sm cursor-pointer">
          <img src="/tik tok.png" width="20" height="20" alt="TikTok" />
          Ver más videos en TikTok
        </button>
      </a>
    </div>
  </div>
</div>
