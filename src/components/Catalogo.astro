---
import CasaCard from './CasaCard.astro'
import casas from '../data/casas.json'
---

<section id="catalogo" class="py-24 bg-stone-50">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="text-brand-500 text-sm font-semibold tracking-widest uppercase">Nuestros modelos</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-stone-800 mt-2 mb-4">
        Catálogo de viviendas
      </h2>
      <p class="text-stone-500 text-lg max-w-xl mx-auto">
        Encuentra el modelo que se adapta a tu familia, terreno y presupuesto.
      </p>
    </div>

    <!-- Filtros -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-5 mb-10 flex flex-wrap gap-4 items-end">

      <div class="flex flex-col gap-1.5 min-w-[150px]">
        <label class="text-xs font-semibold text-stone-500 uppercase tracking-wide">Dormitorios</label>
        <select id="filtro-dorm" class="px-4 py-2.5 bg-stone-50 border border-stone-200 rounded-lg text-sm text-stone-700 focus:outline-none focus:ring-2 focus:ring-brand-300">
          <option value="0">Todos</option>
          <option value="1">1 dormitorio</option>
          <option value="2">2 dormitorios</option>
          <option value="3">3 dormitorios</option>
          <option value="4">4 dormitorios</option>
        </select>
      </div>

      <div class="flex flex-col gap-1.5 min-w-[200px]">
        <label class="text-xs font-semibold text-stone-500 uppercase tracking-wide">
          Precio máximo: <span id="precio-label" class="text-brand-600">UF 5.000</span>
        </label>
        <input
          id="filtro-precio"
          type="range"
          min="1000"
          max="5000"
          step="100"
          value="5000"
          class="w-full accent-brand-500"
        />
      </div>

      <div class="flex flex-col gap-1.5 min-w-[150px]">
        <label class="text-xs font-semibold text-stone-500 uppercase tracking-wide">Superficie mín.</label>
        <select id="filtro-sup" class="px-4 py-2.5 bg-stone-50 border border-stone-200 rounded-lg text-sm text-stone-700 focus:outline-none focus:ring-2 focus:ring-brand-300">
          <option value="0">Cualquiera</option>
          <option value="36">36 m²+</option>
          <option value="54">54 m²+</option>
          <option value="72">72 m²+</option>
          <option value="90">90 m²+</option>
          <option value="108">108 m²+</option>
        </select>
      </div>

      <button
        id="btn-limpiar"
        class="px-5 py-2.5 text-sm font-medium text-stone-500 hover:text-stone-700 hover:bg-stone-100 rounded-lg transition-colors"
      >
        Limpiar filtros
      </button>

      <div class="ml-auto text-sm text-stone-400">
        <span id="contador">12</span> modelos
      </div>
    </div>

    <!-- Grid de casas -->
    <div id="casas-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {casas.map(casa => (
        <CasaCard
          id={casa.id}
          slug={casa.slug}
          modelo={casa.modelo}
          superficie={casa.superficie}
          dormitorios={casa.dormitorios}
          banos={casa.banos}
          precio={casa.precio}
          imagen={casa.imagen}
          tag={casa.tag}
        />
      ))}
    </div>

    <!-- Sin resultados -->
    <div id="sin-resultados" class="hidden text-center py-16">
      <div class="text-5xl mb-4">🏠</div>
      <h3 class="font-display text-xl font-bold text-stone-700 mb-2">Sin resultados</h3>
      <p class="text-stone-400">Prueba ajustando los filtros de búsqueda.</p>
    </div>

  </div>
</section>

<script>
  const cards    = document.querySelectorAll<HTMLElement>('.casa-card')
  const filtDorm = document.getElementById('filtro-dorm') as HTMLSelectElement
  const filtPrec = document.getElementById('filtro-precio') as HTMLInputElement
  const filtSup  = document.getElementById('filtro-sup') as HTMLSelectElement
  const precioLabel = document.getElementById('precio-label')!
  const contador    = document.getElementById('contador')!
  const sinResultados = document.getElementById('sin-resultados')!

  function aplicarFiltros() {
    const dorm  = Number(filtDorm.value)
    const prec  = Number(filtPrec.value)
    const sup   = Number(filtSup.value)

    precioLabel.textContent = `UF ${prec.toLocaleString('es-CL')}`

    let visibles = 0
    cards.forEach(card => {
      const cDorm = Number(card.dataset.dormitorios)
      const cPrec = Number(card.dataset.precio)
      const cSup  = Number(card.dataset.superficie)

      const ok =
        (dorm === 0 || cDorm === dorm) &&
        cPrec <= prec &&
        cSup >= sup

      card.style.display = ok ? '' : 'none'
      if (ok) visibles++
    })

    contador.textContent = String(visibles)
    sinResultados.classList.toggle('hidden', visibles > 0)
  }

  filtDorm.addEventListener('change', aplicarFiltros)
  filtPrec.addEventListener('input', aplicarFiltros)
  filtSup.addEventListener('change', aplicarFiltros)

  document.getElementById('btn-limpiar')!.addEventListener('click', () => {
    filtDorm.value = '0'
    filtPrec.value = '5000'
    filtSup.value  = '0'
    aplicarFiltros()
  })
</script>
