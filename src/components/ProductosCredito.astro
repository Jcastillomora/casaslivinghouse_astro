---
// Productos de crédito — replica exacta de Casaslivinghouse.py (productos_credito_section)
const features = [
  {
    icono: "shield-check",
    titulo: "Con o Sin DICOM",
    descripcion: "Evaluamos cada caso de forma flexible y personalizada, sin importar tu historial crediticio.",
  },
  {
    icono: "calculator",
    titulo: "Pie + Cuotas Accesibles",
    descripcion: "Define el monto del pie y distribuye el saldo en cuotas mensuales adaptadas a tu presupuesto.",
  },
  {
    icono: "credit-card",
    titulo: "Paga con Tarjeta",
    descripcion: "Acepta tarjetas de crédito y débito para el pago del pie inicial de tu vivienda.",
  },
  {
    icono: "map-pin",
    titulo: "Proyectos Turísticos",
    descripcion: "Financia cabañas y construcciones para proyectos turísticos en el sur de Chile.",
  },
];
---

<!-- Productos Crédito — replica exacta -->
<div
  class="w-full"
  style="background: linear-gradient(180deg, #f8fafc 0%, #f0fdfa 100%);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 mb-12">
      <span class="text-teal-600 text-xs font-bold uppercase tracking-widest">FINANCIAMIENTO</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 text-center leading-tight">
        Tu casa con crédito directo
      </h2>
      <p class="text-slate-500 text-base text-center max-w-xl">
        Sin banco, sin trámites complicados. Evaluamos tu caso de forma personalizada.
      </p>
    </div>

    <!-- Layout: columna izq (card verde) + columna der (4 features) -->
    <div class="flex flex-col lg:flex-row gap-6 items-stretch">
      <!-- Columna izquierda: Crédito Directo -->
      <div
        class="lg:w-2/5 p-8 rounded-2xl flex flex-col"
        style="background: linear-gradient(135deg, #0f766e 0%, #0d9488 50%, #14b8a6 100%); min-height: 100%;"
      >
        <div class="p-3 bg-white/15 rounded-xl w-fit mb-6">
          <i data-lucide="banknote" class="w-11 h-11 text-white" style="color:white;width:44px;height:44px;"></i>
        </div>
        <h3 class="text-white text-3xl font-black mb-2">Crédito Directo</h3>
        <p class="text-white/80 text-sm leading-relaxed mb-2">
          Financia tu casa directamente con nosotros, sin intermediarios bancarios.
        </p>
        <p class="text-white/80 text-sm leading-relaxed mb-6">
          Evaluamos caso a caso. Si no tienes el PIE mínimo, paga tu pié en cuotas, y programamos la entrega diferida de tu vivienda.
        </p>
        <div class="flex flex-col gap-3 mb-8">
          <div class="flex items-center gap-2">
            <i data-lucide="circle-dot" class="w-4 h-4 text-white" style="color:white;width:16px;height:16px;flex-shrink:0;"></i>
            <span class="text-white text-sm">Pie + cuotas mensuales</span>
          </div>
          <div class="flex items-center gap-2">
            <i data-lucide="circle-dot" class="w-4 h-4 text-white" style="color:white;width:16px;height:16px;flex-shrink:0;"></i>
            <span class="text-white text-sm">Con o Sin DICOM</span>
          </div>
          <div class="flex items-center gap-2">
            <i data-lucide="circle-dot" class="w-4 h-4 text-white" style="color:white;width:16px;height:16px;flex-shrink:0;"></i>
            <span class="text-white text-sm">Evaluación personalizada</span>
          </div>
        </div>
        <a href="https://wa.me/56930754516" target="_blank" rel="noopener noreferrer" class="no-underline w-fit">
          <button class="flex items-center gap-2 bg-white text-teal-700 hover:bg-teal-50 font-bold px-6 py-3 rounded-xl transition-all duration-200 shadow-md border-0 cursor-pointer">
            <i data-lucide="message-circle" class="w-4 h-4" style="color:#0f766e;width:16px;height:16px;"></i>
            Consultar ahora
          </button>
        </a>
      </div>

      <!-- Columna derecha: 4 feature cards -->
      <div class="lg:w-3/5 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {features.map(f => (
          <div class="p-5 bg-white rounded-2xl border border-teal-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">
            <div class="flex flex-col gap-2 items-start">
              <div class="p-3 bg-teal-50 rounded-xl w-fit">
                <i data-lucide={f.icono} class="w-5 h-5" style="color:#0d9488;width:22px;height:22px;"></i>
              </div>
              <p class="text-slate-800 font-bold text-base">{f.titulo}</p>
              <p class="text-slate-500 text-sm leading-relaxed">{f.descripcion}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
