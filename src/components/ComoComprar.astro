---
import { Icon } from 'astro-icon/components';

// Proceso de compra — replica exacta de como_comprar.py
const PASOS = [
  {
    numero: "01",
    titulo: "Elige tu modelo",
    descripcion: "Navega por nuestro catálogo y elige el modelo que se adapta a tu terreno y presupuesto.",
    icono: "lucide:home",
  },
  {
    numero: "02",
    titulo: "Solicita tu cotización",
    descripcion: "Te enviamos una cotización detallada con precios, plazos y opciones de financiamiento.",
    icono: "lucide:file-text",
  },
  {
    numero: "03",
    titulo: "Firmamos el contrato",
    descripcion: "Acordamos los términos comerciales y firmamos el contrato de compraventa con garantías.",
    icono: "lucide:file-check",
  },
  {
    numero: "04",
    titulo: "Fabricamos tu kit",
    descripcion: "Iniciamos la fabricación de los paneles y la estructura de tu futura vivienda.",
    icono: "lucide:hammer",
  },
  {
    numero: "05",
    titulo: "Despachamos a tu terreno",
    descripcion: "Coordinamos el despacho de todos los materiales directamente a tu propiedad.",
    icono: "lucide:truck",
  },
  {
    numero: "06",
    titulo: "Montamos tu hogar si contratas también este servicio adicional.",
    descripcion: "Nuestro equipo realiza el montaje y en pocas semanas tienes tu casa lista para vivir.",
    icono: "lucide:key",
  },
];
---

<!-- Cómo Comprar — replica exacta de como_comprar.py -->
<div
  class="w-full"
  style="background: linear-gradient(180deg, #ffffff 0%, #f0fdfa 60%, #ccfbf1 100%);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <!-- Header -->
    <div class="flex flex-col items-center gap-4 mb-14">
      <span class="text-teal-600 text-xs font-bold uppercase tracking-widest">PROCESO DE COMPRA</span>
      <h2 class="text-3xl md:text-5xl font-bold text-slate-900 text-center leading-tight">
        ¿Cómo comprar tu casa?
      </h2>
      <p class="text-slate-500 text-base text-center max-w-xl">
        En 6 simples pasos puedes tener la casa de tus sueños.
      </p>
    </div>

    <!-- Grid de pasos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {PASOS.map(paso => (
        <div class="relative p-6 bg-white rounded-2xl border border-teal-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 overflow-hidden">
          <!-- Número decorativo de fondo -->
          <span class="absolute top-3 right-4 text-6xl font-black text-teal-100 leading-none select-none pointer-events-none">
            {paso.numero}
          </span>
          <!-- Contenido -->
          <div class="flex flex-col gap-3 items-start">
            <div class="p-3 bg-teal-50 rounded-xl w-fit">
              <Icon name={paso.icono} style="color:#0d9488;width:22px;height:22px;" />
            </div>
            <p class="text-slate-800 font-bold text-lg leading-snug">{paso.titulo}</p>
            <p class="text-slate-500 text-sm leading-relaxed">{paso.descripcion}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="flex justify-center mt-12">
      <a href="https://wa.me/56930754516" target="_blank" rel="noopener noreferrer" class="no-underline">
        <button class="flex items-center gap-2 bg-teal-600 hover:bg-teal-500 text-white font-semibold px-8 py-3 rounded-xl transition-all duration-200 shadow-lg shadow-teal-500/20 border-0 cursor-pointer">
          <Icon name="lucide:message-circle" style="width:16px;height:16px;" />
          Iniciar el proceso por WhatsApp
        </button>
      </a>
    </div>
  </div>
</div>
