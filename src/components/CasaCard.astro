---
export interface Props {
  id: number
  slug: string
  modelo: string
  superficie: number
  dormitorios: number
  banos: number
  precio: number
  imagen: string
  tag?: string
}
const { id, slug, modelo, superficie, dormitorios, banos, precio, imagen, tag } = Astro.props
---

<article
  class="casa-card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group"
  data-dormitorios={dormitorios}
  data-precio={precio}
  data-superficie={superficie}
>
  <!-- Imagen -->
  <div class="relative overflow-hidden aspect-[4/3]">
    <img
      src={imagen}
      alt={`Casa ${modelo}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      onerror="this.src='/assets/foto_placeholder.jpg'"
    />
    {tag && (
      <span class="absolute top-3 left-3 bg-brand-500 text-white text-xs font-semibold px-3 py-1 rounded-full shadow-md">
        {tag}
      </span>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-stone-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
  </div>

  <!-- Info -->
  <div class="p-5">
    <div class="flex items-start justify-between mb-3">
      <div>
        <h3 class="font-display font-bold text-lg text-stone-800">{modelo}</h3>
        <p class="text-stone-400 text-sm">{superficie} m²</p>
      </div>
      <div class="text-right">
        <div class="text-brand-600 font-bold text-lg">UF {precio.toLocaleString('es-CL')}</div>
        <div class="text-stone-400 text-xs">precio base</div>
      </div>
    </div>

    <!-- Specs -->
    <div class="flex gap-4 mb-4 py-3 border-t border-stone-100">
      <div class="flex items-center gap-1.5 text-stone-500 text-sm">
        <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span>{dormitorios} dorm.</span>
      </div>
      <div class="flex items-center gap-1.5 text-stone-500 text-sm">
        <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span>{banos} baño{banos > 1 ? 's' : ''}</span>
      </div>
      <div class="flex items-center gap-1.5 text-stone-500 text-sm">
        <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
        </svg>
        <span>{superficie} m²</span>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex gap-2">
      <a
        href={`/casa/${slug}`}
        class="flex-1 py-2.5 text-center text-sm font-semibold text-brand-600 border border-brand-200 rounded-lg hover:bg-brand-50 transition-colors"
      >
        Ver detalle
      </a>
      <a
        href={`https://wa.me/56930754516?text=Hola, me interesa el modelo ${modelo} (${superficie}m²)`}
        target="_blank"
        rel="noopener"
        class="flex-1 py-2.5 text-center text-sm font-semibold text-white bg-brand-500 hover:bg-brand-400 rounded-lg transition-colors"
      >
        Cotizar
      </a>
    </div>
  </div>
</article>
