---
import equipo from '../data/equipo.json'
---

<section id="quienes-somos" class="py-24 bg-stone-800 text-white">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Texto -->
      <div>
        <span class="text-brand-400 text-sm font-semibold tracking-widest uppercase">Quiénes somos</span>
        <h2 class="font-display text-4xl md:text-5xl font-bold mt-2 mb-6 leading-tight">
          Construimos hogares<br/>
          <span class="text-brand-400">desde el sur</span>
        </h2>
        <p class="text-stone-300 text-lg leading-relaxed mb-6">
          Somos una empresa familiar del centro-sur de Chile con más de 15 años de experiencia
          en viviendas prefabricadas. Conocemos el clima, la geografía y las necesidades
          reales de las familias de nuestra región.
        </p>
        <p class="text-stone-400 leading-relaxed mb-8">
          Cada vivienda se fabrica con materiales de alta durabilidad pensados para resistir
          las lluvias y temperaturas del sur. Trabajamos con proveedores locales y entregamos
          con garantía de construcción.
        </p>

        <!-- Valores -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { icon: '🏆', label: 'Calidad certificada' },
            { icon: '⚡', label: 'Entrega rápida' },
            { icon: '🤝', label: 'Trato directo' },
            { icon: '🌿', label: 'Materiales locales' },
          ].map(v => (
            <div class="flex items-center gap-3 bg-stone-700/50 rounded-xl px-4 py-3">
              <span class="text-xl">{v.icon}</span>
              <span class="text-sm font-medium text-stone-200">{v.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Equipo -->
      <div class="flex flex-col gap-6">
        <h3 class="text-lg font-semibold text-stone-300">Nuestro equipo</h3>
        {equipo.map(persona => (
          <div class="flex items-center gap-5 bg-stone-700/40 border border-stone-600/40 rounded-2xl p-5 hover:bg-stone-700/60 transition-colors">
            <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0 bg-stone-600">
              <img
                src={persona.foto}
                alt={persona.nombre}
                class="w-full h-full object-cover"
                loading="lazy"
                onerror="this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-2xl\'>👤</div>'"
              />
            </div>
            <div>
              <div class="font-display font-bold text-white">{persona.nombre}</div>
              <div class="text-brand-400 text-sm font-medium mb-1">{persona.cargo}</div>
              <div class="text-stone-400 text-sm leading-snug">{persona.descripcion}</div>
            </div>
          </div>
        ))}

        <!-- Foto empresa -->
        <div class="rounded-2xl overflow-hidden aspect-video bg-stone-700">
          <img
            src="/assets/foto_hero1.jpg"
            alt="Casas Living House"
            class="w-full h-full object-cover opacity-80"
            loading="lazy"
          />
        </div>
      </div>
    </div>

  </div>
</section>
