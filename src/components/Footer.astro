---
---

<footer id="contacto" class="bg-stone-900 text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Marca -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 bg-brand-500 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
          </div>
          <span class="font-display font-bold text-lg">Living House</span>
        </div>
        <p class="text-stone-400 text-sm leading-relaxed mb-6">
          Viviendas prefabricadas de calidad para el centro-sur de Chile.
          Más de 15 años construyendo hogares familiares.
        </p>
        <!-- WhatsApp -->
        <a
          href="https://wa.me/56930754516"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-500 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors shadow"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.126.554 4.12 1.525 5.855L.057 23.882l6.174-1.618A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.007-1.373l-.36-.213-3.664.961.977-3.563-.234-.376A9.818 9.818 0 1112 21.818z"/>
          </svg>
          +56 9 3075 4516
        </a>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wide">Navegación</h4>
        <ul class="flex flex-col gap-2">
          {['#catalogo', '#como-comprar', '#quienes-somos', '#testimonios'].map((href, i) => (
            <li>
              <a
                href={href}
                class="text-stone-400 hover:text-brand-400 text-sm transition-colors"
              >
                {['Catálogo', 'Cómo comprar', 'Quiénes somos', 'Testimonios'][i]}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wide">Contacto</h4>
        <ul class="flex flex-col gap-3 text-sm text-stone-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            +56 9 3075 4516
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Centro Sur de Chile
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.07-.1z"/>
            </svg>
            <a href="https://www.tiktok.com/@casaslivinghouse" target="_blank" rel="noopener" class="hover:text-brand-400 transition-colors">
              @casaslivinghouse
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-stone-800 pt-6 text-center text-stone-500 text-xs">
      © {new Date().getFullYear()} Casas Living House. Todos los derechos reservados.
    </div>

  </div>
</footer>
