---
---
<!-- Footer — replica exacta de footer.py -->
<footer
  class="w-full border-t border-teal-900/60"
  style="background: linear-gradient(180deg, #134e4a 0%, #0d9488 60%, #14b8a6 100%);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
    <!-- Main grid -->
    <div class="flex flex-col md:flex-row justify-between gap-8 w-full">

      <!-- Brand + socials -->
      <div class="flex flex-col gap-5 items-start">
        <div class="flex items-center gap-3">
          <img
            src="/casaslivinghouse.jpg"
            alt="Casas Living House"
            width="50"
            height="50"
            class="rounded-full object-cover"
            style="width:50px;height:50px;box-shadow:0 0 0 2px rgba(20,184,166,0.4);"
          />
          <div class="card_loader text-center">
            <div class="loader">
              <span class="text-white font-bold" style="font-size:clamp(11px,1.8vw,17px);">Somos Casas Living House</span>
              <div class="words">
                <span class="word">Gracias a Dios</span>
                <span class="word"></span>
              </div>
            </div>
          </div>
        </div>
        <p class="text-teal-50 text-sm leading-relaxed max-w-xs">
          Empresa del centro sur de Chile dedicada al desarrollo inmobiliario y al sueño de la casa propia.
        </p>
        <!-- Socials -->
        <div class="flex flex-col gap-3">
          <h3 class="text-white uppercase tracking-wider text-xs mb-1 font-bold">Síguenos</h3>
          <div class="flex items-center gap-6">
            <div class="flex flex-col items-center gap-1">
              <span class="text-teal-100 text-xs">TikTok</span>
              <a href="https://www.tiktok.com/@casaslivinghouse?lang=es" target="_blank" rel="noopener noreferrer" class="no-underline">
                <img src="/tik tok.png" width="28" height="28" alt="TikTok" class="opacity-70 hover:opacity-100 transition-opacity duration-200" />
              </a>
            </div>
            <div class="flex flex-col items-center gap-1">
              <span class="text-teal-100 text-xs">Facebook</span>
              <a href="https://www.facebook.com/casas.living.house.casasprefabricadas/" target="_blank" rel="noopener noreferrer" class="no-underline">
                <img src="/facebook.png" width="28" height="28" alt="Facebook" class="opacity-70 hover:opacity-100 transition-opacity duration-200" />
              </a>
            </div>
            <div class="flex flex-col items-center gap-1">
              <span class="text-teal-100 text-xs">Instagram</span>
              <a href="https://www.instagram.com/casasprefabricadaslivinghouse/" target="_blank" rel="noopener noreferrer" class="no-underline">
                <img src="/instagram.png" width="28" height="28" alt="Instagram" class="opacity-70 hover:opacity-100 transition-opacity duration-200" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Casa Matriz: Temuco -->
      <div class="flex flex-col gap-4 sm:items-center">
        <h3 class="text-white font-bold mb-2">Casa Matriz – Temuco</h3>
        <div class="sm:flex sm:justify-center sm:items-center">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d925.2100535091267!2d-72.59130711404337!3d-38.740231196906635!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9614d3ddfd0f408d%3A0x77568596c6b5195d!2sArturo%20Prat%20696%2C%20Of%20316%2C%204792393%20Temuco%2C%20Araucan%C3%ADa!5e0!3m2!1ses-419!2scl!4v1772550902416!5m2!1ses-419!2scl"
            width="200"
            height="200"
            style="border:0;border-radius:0.75rem;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <div class="flex items-center gap-2">
          <i data-lucide="map-pinned" class="w-5 h-5" style="color:crimson;width:20px;height:20px;flex-shrink:0;"></i>
          <span class="text-teal-50 text-sm">Arturo Prat N° 696, oficina 316, Temuco</span>
        </div>
      </div>

      <!-- Sucursal: La Unión -->
      <div class="flex flex-col gap-4 sm:items-center">
        <h3 class="text-white font-bold mb-2">Sucursal – La Unión</h3>
        <div class="sm:flex sm:justify-center sm:items-center">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3045.6789268958078!2d-72.5969385!3d-40.238440499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f10.0!3m3!1m2!1s0x96166b0d928567ad%3A0x5a7a5fd2914d1d11!2sCasas%20Prefabricadas%20Living%20House!5e0!3m2!1ses!2scl!4v1755174836639!5m2!1ses!2scl"
            width="200"
            height="200"
            style="border:0;border-radius:0.75rem;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <div class="flex items-center gap-2">
          <i data-lucide="map-pinned" class="w-5 h-5" style="color:crimson;width:20px;height:20px;flex-shrink:0;"></i>
          <span class="text-teal-50 text-sm">Ruta T 75 KM 35 Sector Puerto Nuevo, La Unión</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <hr class="border-slate-700/50 my-8" />

    <!-- Bottom bar -->
    <div class="flex justify-center w-full">
      <p class="text-teal-100 text-sm text-center">
        © 2026 Casas Prefabricadas Living House — Todos los derechos reservados
      </p>
    </div>
  </div>
</footer>
