---
---
<!-- Hero Section — replica exacta de hero_section.py -->
<div class="w-full">
  <!-- Hero principal -->
  <div class="bg-gradient-to-br from-slate-900 via-teal-950/80 to-slate-900">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">

        <!-- Columna izquierda: texto -->
        <div class="flex flex-col gap-6 items-start py-10 lg:py-16">
          <!-- Badge -->
          <div class="bg-teal-500/15 border border-teal-500/30 px-3 py-1.5 rounded-full w-fit">
            <div class="flex items-center gap-2">
              <i data-lucide="home" class="w-3.5 h-3.5 text-teal-300" style="color:#5eead4;width:14px;height:14px;"></i>
              <span class="text-teal-300 text-sm font-medium">Casas Prefabricadas de Calidad</span>
            </div>
          </div>

          <!-- Heading -->
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
            Tu hogar, hecho realidad
          </h1>

          <!-- Description -->
          <p class="text-white/90 text-base md:text-lg leading-relaxed max-w-xl">
            Somos Casas Prefabricadas Living House ¡Gracias a Dios!
            Una empresa que te acompaña en cada uno de tus sueños.
          </p>

          <!-- Christian message -->
          <div class="flex items-center gap-2">
            <i data-lucide="heart" class="w-4 h-4" style="color:#5eead4;width:16px;height:16px;flex-shrink:0;"></i>
            <span class="text-white/85 font-semibold text-sm md:text-base">
              Empresa de inspiración Cristiana somos confianza, somos realidad.
            </span>
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4">
            <a href="#modelos" class="no-underline">
              <button class="flex items-center gap-2 px-6 py-2.5 bg-teal-500 hover:bg-teal-400 text-white font-semibold rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-teal-500/30 border-0 cursor-pointer text-base">
                Ver Catálogo
                <i data-lucide="arrow-right" class="w-4 h-4" style="width:17px;height:17px;"></i>
              </button>
            </a>
            <a href="https://wa.me/56930754516" target="_blank" rel="noopener noreferrer" class="no-underline">
              <button class="flex items-center gap-2 px-6 py-2.5 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl transition-all duration-200 border border-white/20 cursor-pointer text-base">
                <i data-lucide="message-circle" class="w-4 h-4" style="width:17px;height:17px;"></i>
                Contáctanos
              </button>
            </a>
          </div>
        </div>

        <!-- Columna derecha: slider de imágenes -->
        <div>
          <div class="hero-slider-container shadow-2xl shadow-black/40">
            <div class="hero-slider-track">
              <div class="hero-slide-item">
                <img src="/volcan_osorno_137.jpg" alt="Casa Volcán Osorno 137m²" />
              </div>
              <div class="hero-slide-item">
                <img src="/7lagos_108.jpg" alt="Casa 7 Lagos 108m²" />
              </div>
              <div class="hero-slide-item">
                <img src="/foto_sección 1.jpg" alt="Casa Living House" />
              </div>
              <div class="hero-slide-item">
                <img src="/puerto_octay_90.jpg" alt="Casa Puerto Octay 90m²" />
              </div>
            </div>
            <div class="hero-slide-overlay"></div>
          </div>
          <!-- Dot indicators -->
          <div class="hero-dots mt-3">
            <div class="hero-dot hero-dot-1"></div>
            <div class="hero-dot hero-dot-2"></div>
            <div class="hero-dot hero-dot-3"></div>
            <div class="hero-dot hero-dot-4"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar-animated border-t border-white/10 mt-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:flex md:flex-row items-center justify-center gap-6 md:gap-10 py-6 px-4">
          <!-- Stat: modelos -->
          <div class="flex flex-row items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-purple-500/30">
              <i data-lucide="building-2" class="w-5 h-5 text-white" style="color:white;width:22px;height:22px;"></i>
            </div>
            <div>
              <p class="text-2xl md:text-3xl font-black text-white leading-none">20+</p>
              <p class="text-xs text-slate-400 mt-1 whitespace-nowrap">Modelos disponibles</p>
            </div>
          </div>
          <div class="hidden md:block w-px h-10 bg-white/20"></div>
          <!-- Stat: años -->
          <div class="flex flex-row items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-yellow-500/30">
              <i data-lucide="calendar" class="w-5 h-5 text-white" style="color:white;width:22px;height:22px;"></i>
            </div>
            <div>
              <p class="text-2xl md:text-3xl font-black text-white leading-none">5+</p>
              <p class="text-xs text-slate-400 mt-1 whitespace-nowrap">Años de experiencia</p>
            </div>
          </div>
          <div class="hidden md:block w-px h-10 bg-white/20"></div>
          <!-- Stat: crédito -->
          <div class="flex flex-row items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-teal-500/30">
              <i data-lucide="banknote" class="w-5 h-5 text-white" style="color:white;width:22px;height:22px;"></i>
            </div>
            <div>
              <p class="text-2xl md:text-3xl font-black text-white leading-none">100%</p>
              <p class="text-xs text-slate-400 mt-1 whitespace-nowrap">Crédito Directo</p>
            </div>
          </div>
          <div class="hidden md:block w-px h-10 bg-white/20"></div>
          <!-- Stat: sin DICOM -->
          <div class="flex flex-row items-center gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-sky-500/30">
              <i data-lucide="shield-check" class="w-5 h-5 text-white" style="color:white;width:22px;height:22px;"></i>
            </div>
            <div>
              <p class="text-2xl md:text-3xl font-black text-white leading-none">Sin DICOM</p>
              <p class="text-xs text-slate-400 mt-1 whitespace-nowrap">Evaluación flexible</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
