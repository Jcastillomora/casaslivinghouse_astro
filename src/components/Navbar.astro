
---
---
<!-- Navbar — replica exacta de navbar.py -->
<nav
  x-data="{ open: false }"
  style="background: linear-gradient(135deg, #0d9488 0%, #14b8a6 60%, #0f766e 100%);"
  class="top-0 z-50 w-full px-4 py-3 border-b border-teal-700/30 shadow-lg"
>
  <!-- ── Desktop ── -->
  <div class="hidden md:flex items-center justify-between w-full px-4">
    <!-- Logo -->
    <div class="flex items-center gap-3">
      <img
        src="/casaslivinghouse.jpg"
        alt="Casas Living House"
        width="46"
        height="46"
        class="rounded-full object-cover ring-2 ring-white/40 shadow-md"
        style="width:46px;height:46px;"
      />
      <div class="card_loader w-full text-center">
        <div class="loader">
          <span class="text-white font-bold" style="font-size:clamp(11px,1.8vw,17px);">Somos Casas Living House</span>
          <div class="words">
            <span class="word">Gracias a Dios</span>
            <span class="word"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Links -->
    <div class="flex items-center gap-8">
      <a href="/#inicio" class="flex items-center gap-2 text-white/90 hover:text-white transition-colors duration-200 no-underline">
        <i data-lucide="home" class="w-4 h-4"></i>
        <span class="text-sm font-medium">Inicio</span>
      </a>
      <a href="/#nosotros" class="flex items-center gap-2 text-white/90 hover:text-white transition-colors duration-200 no-underline">
        <i data-lucide="users" class="w-4 h-4"></i>
        <span class="text-sm font-medium">Nosotros</span>
      </a>
      <a href="/#modelos" class="flex items-center gap-2 text-white/90 hover:text-white transition-colors duration-200 no-underline">
        <i data-lucide="building-2" class="w-4 h-4"></i>
        <span class="text-sm font-medium">Modelos</span>
      </a>
      <a href="/#contacto" class="flex items-center gap-2 text-white/90 hover:text-white transition-colors duration-200 no-underline">
        <i data-lucide="mail" class="w-4 h-4"></i>
        <span class="text-sm font-medium">Contacto</span>
      </a>
    </div>

    <!-- CTA -->
    <a href="https://wa.me/56930754516" target="_blank" rel="noopener noreferrer" class="no-underline">
      <button class="flex items-center gap-2 bg-white text-teal-700 hover:bg-teal-50 text-sm font-bold px-4 py-2 rounded-xl transition-all duration-200 shadow-md border-0 cursor-pointer">
        <i data-lucide="phone" class="w-4 h-4"></i>
        +56 9 3075 4516
      </button>
    </a>
  </div>

  <!-- ── Mobile ── -->
  <div class="md:hidden w-full">
    <!-- Top bar -->
    <div class="flex items-center justify-between w-full">
      <div class="flex items-center gap-2">
        <img
          src="/casaslivinghouse.jpg"
          alt="Casas Living House"
          width="40"
          height="40"
          class="rounded-full object-cover ring-2 ring-white/40"
          style="width:40px;height:40px;"
        />
        <div class="card_loader text-center">
          <div class="loader">
            <span class="text-white font-bold" style="font-size:clamp(11px,1.8vw,17px);">Somos Casas Living House</span>
            <div class="words">
              <span class="word">Gracias a Dios</span>
              <span class="word"></span>
            </div>
          </div>
        </div>
      </div>
      <!-- Hamburger -->
      <button
        @click="open = !open"
        class="p-2 rounded-lg hover:bg-white/15 transition-colors cursor-pointer border-0 bg-transparent"
        aria-label="Menú"
      >
        <i x-show="!open" data-lucide="menu" class="w-5 h-5 text-white" style="color:white;"></i>
        <i x-show="open" x-cloak data-lucide="x" class="w-5 h-5 text-white" style="color:white;"></i>
      </button>
    </div>

    <!-- Dropdown -->
    <div x-show="open" x-cloak class="w-full border-t border-teal-700/30 mt-1">
      <a href="/#inicio" @click="open=false" class="flex items-center gap-3 py-3 px-6 border-b border-teal-700/30 hover:bg-teal-700/30 transition-colors text-white/90 hover:text-white no-underline">
        <i data-lucide="home" class="w-5 h-5"></i>
        <span class="text-base font-medium">Inicio</span>
      </a>
      <a href="/#nosotros" @click="open=false" class="flex items-center gap-3 py-3 px-6 border-b border-teal-700/30 hover:bg-teal-700/30 transition-colors text-white/90 hover:text-white no-underline">
        <i data-lucide="users" class="w-5 h-5"></i>
        <span class="text-base font-medium">Nosotros</span>
      </a>
      <a href="/#modelos" @click="open=false" class="flex items-center gap-3 py-3 px-6 border-b border-teal-700/30 hover:bg-teal-700/30 transition-colors text-white/90 hover:text-white no-underline">
        <i data-lucide="building-2" class="w-5 h-5"></i>
        <span class="text-base font-medium">Modelos</span>
      </a>
      <a href="/#contacto" @click="open=false" class="flex items-center gap-3 py-3 px-6 border-b border-teal-700/30 hover:bg-teal-700/30 transition-colors text-white/90 hover:text-white no-underline">
        <i data-lucide="mail" class="w-5 h-5"></i>
        <span class="text-base font-medium">Contacto</span>
      </a>
      <a href="https://wa.me/56930754516" target="_blank" rel="noopener noreferrer" @click="open=false" class="flex items-center gap-3 py-3 px-6 hover:bg-teal-700/30 transition-colors text-white/90 hover:text-white no-underline">
        <i data-lucide="phone" class="w-5 h-5"></i>
        <span class="text-base font-medium">+56 9 3075 4516</span>
      </a>
    </div>
  </div>
</nav>

<style>
  a { text-decoration: none; }
</style>
