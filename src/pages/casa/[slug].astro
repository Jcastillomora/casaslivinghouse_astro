---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import Whatsapp from '../../components/Whatsapp.astro'
import casas from '../../data/casas.json'

export function getStaticPaths() {
  return casas.map(casa => ({
    params: { slug: casa.slug },
    props:  { casa },
  }))
}

const { casa } = Astro.props
const relacionadas = casas.filter(c => c.id !== casa.id && c.dormitorios === casa.dormitorios).slice(0, 3)
---

<Layout
  title={`${casa.modelo} — Casas Living House`}
  description={casa.descripcion}
>
  <Navbar />

  <main class="pt-20">

    <!-- Breadcrumb -->
    <div class="bg-stone-100 border-b border-stone-200">
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center gap-2 text-sm text-stone-500">
        <a href="/" class="hover:text-brand-600 transition-colors">Inicio</a>
        <span>/</span>
        <a href="/#catalogo" class="hover:text-brand-600 transition-colors">Catálogo</a>
        <span>/</span>
        <span class="text-stone-700 font-medium">{casa.modelo}</span>
      </div>
    </div>

    <!-- Detalle -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

          <!-- Imágenes -->
          <div class="flex flex-col gap-4">
            <div class="rounded-2xl overflow-hidden aspect-[4/3] bg-stone-100 shadow-md">
              <img
                src={casa.imagen}
                alt={`Casa ${casa.modelo}`}
                class="w-full h-full object-cover"
                loading="eager"
                onerror="this.src='/assets/foto_placeholder.jpg'"
              />
            </div>
            {casa.plano && (
              <div class="rounded-xl overflow-hidden aspect-[4/3] bg-stone-50 border border-stone-200">
                <img
                  src={casa.plano}
                  alt={`Plano ${casa.modelo}`}
                  class="w-full h-full object-contain p-4"
                  loading="lazy"
                />
              </div>
            )}
          </div>

          <!-- Info -->
          <div class="sticky top-24">
            {casa.tag && (
              <span class="inline-block bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full mb-4">
                {casa.tag}
              </span>
            )}

            <h1 class="font-display text-4xl font-bold text-stone-800 mb-2">{casa.modelo}</h1>
            <p class="text-stone-500 text-lg mb-6">{casa.superficie} m² construidos</p>

            <!-- Precio -->
            <div class="bg-brand-50 border border-brand-100 rounded-2xl p-5 mb-6">
              <div class="text-stone-500 text-sm mb-1">Precio base</div>
              <div class="font-display text-4xl font-bold text-brand-600">
                UF {casa.precio.toLocaleString('es-CL')}
              </div>
              <div class="text-stone-400 text-xs mt-1">Incluye fabricación y montaje. Instalaciones y terreno no incluidos.</div>
            </div>

            <!-- Specs -->
            <div class="grid grid-cols-3 gap-3 mb-6">
              {[
                { label: 'Dormitorios', val: casa.dormitorios, icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
                { label: 'Baños', val: casa.banos, icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
                { label: 'm²', val: casa.superficie, icon: 'M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4' },
              ].map(s => (
                <div class="bg-stone-50 border border-stone-100 rounded-xl p-3 text-center">
                  <svg class="w-5 h-5 text-brand-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon} />
                  </svg>
                  <div class="font-bold text-stone-800">{s.val}</div>
                  <div class="text-xs text-stone-500">{s.label}</div>
                </div>
              ))}
            </div>

            <!-- Descripción -->
            <p class="text-stone-600 leading-relaxed mb-8">{casa.descripcion}</p>

            <!-- CTAs -->
            <div class="flex flex-col gap-3">
              <a
                href={`https://wa.me/56930754516?text=Hola, me interesa el modelo ${casa.modelo} (${casa.superficie}m², UF ${casa.precio}). ¿Me pueden dar más información?`}
                target="_blank"
                rel="noopener"
                class="w-full py-4 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-xl text-center transition-all hover:-translate-y-0.5 shadow-lg hover:shadow-xl flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.126.554 4.12 1.525 5.855L.057 23.882l6.174-1.618A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.007-1.373l-.36-.213-3.664.961.977-3.563-.234-.376A9.818 9.818 0 1112 21.818z"/>
                </svg>
                Cotizar por WhatsApp
              </a>
              <a
                href="/#catalogo"
                class="w-full py-3 border border-stone-200 text-stone-600 hover:bg-stone-50 font-medium rounded-xl text-center transition-colors"
              >
                ← Ver todos los modelos
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Modelos relacionados -->
    {relacionadas.length > 0 && (
      <section class="py-16 bg-stone-50">
        <div class="max-w-7xl mx-auto px-6">
          <h2 class="font-display text-2xl font-bold text-stone-800 mb-8">También te puede interesar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {relacionadas.map(r => (
              <a href={`/casa/${r.slug}`} class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 group">
                <div class="aspect-[4/3] overflow-hidden bg-stone-100">
                  <img src={r.imagen} alt={r.modelo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                </div>
                <div class="p-4">
                  <div class="font-display font-bold text-stone-800">{r.modelo}</div>
                  <div class="text-stone-400 text-sm">{r.superficie} m² · UF {r.precio.toLocaleString('es-CL')}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer />
  <Whatsapp />
</Layout>
